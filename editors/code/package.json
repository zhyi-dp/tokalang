{
  "name": "toka-vscode",
  "displayName": "Toka Language Support",
  "description": "Syntax highlighting and language support for Toka",
  "version": "0.1.1",
  "publisher": "zhyi",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhyi-dp/tokalang.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:toka"
  ],
  "contributes": {
    "languages": [
      {
        "id": "toka",
        "aliases": [
          "Toka",
          "toka"
        ],
        "extensions": [
          ".tk"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "toka",
        "scopeName": "source.toka",
        "path": "./syntaxes/toka.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "@vscode/vsce": "^3.7.1"
  }
}
