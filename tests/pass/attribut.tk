import core/traits::{@encap}
import std/io::println

shape S (
    *ptr: [i32]    // Inherits self's mutability as handle mutability; the pointed soul's mutability is not inherited and defaults to immutable
    *buf#: [i32],  // Inherits self's mutability as handle mutability; the pointed soul's content is mutable
    len: i32,      // Inherits self's mutability
    age$: i32 = 18,// Value is internally immutable
    outmut#: i32 // Value is internally mutable
    *#rebind: [i32] // Handle is internally mutable; the pointed soul's mutability is not inherited and defaults to immutable
    // The above '*' examples apply to all pointer types with identical rules, including raw pointer *, unique pointer ^, shared pointer ~, and reference &
)

impl S@encap {
    pub fn clone(self#) -> S {
        return S(*ptr = self.*ptr, *buf = self.*buf, len = self.len, outmut = self.outmut, *rebind = self.*rebind, ..)
    }
    fn drop(self#) {
        println("drop")
        unsafe free self.*ptr
        unsafe free self.*buf
        unsafe free self.*rebind
    }
}

impl S {
    pub fn modify(self#) -> i32 {
        self.len += 1
        //self.age += 1 //forbidden
        self.outmut += 1
        return self.age
    }
}

fn main() -> i32 {
    {
        auto *b# = unsafe alloc [10]i32(0)
        auto *p = unsafe alloc [10]i32(0)
        auto *r# = unsafe alloc [10]i32(0)
        auto s = S(*ptr = *p, *buf = *b, len = 2, outmut = 4, *rebind = *r, ..)
        //auto x = s.modify() //forbidden
        //auto x = s#.modify() //forbidden
        s.outmut += 1 
        // Handle rebinding allowed
        auto *r2# = unsafe alloc [10]i32(0)
        s.*rebind = *r2
        // To avoid leaks, the old ptr must be handled before manually freeing the unneeded one,
        // or we simply do not demonstrate complex rebinding in this simple test
        // and just test the permission boundaries.
        unsafe s.buf[0] += 1
    }
    {
        auto *b# = unsafe alloc [10]i32(0)
        auto *p = unsafe alloc [10]i32(0)
        auto *r# = unsafe alloc [10]i32(0)
        auto s# = S(*ptr = *p, *buf = *b, len = 2, outmut = 4, *rebind = *r, ..)
        //auto x = s.modify() //forbidden
        auto x = s#.modify() // This is a method call where the parameter requires self#, so '#' must be explicitly provided here
    }
    println("Hello World")
    return 0
}