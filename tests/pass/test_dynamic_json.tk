import std/io
import std/io::{println, print}
import core/libc::{libc_printf, libc_fflush}
import std/string::{String}
import core/str::{str, view_str}
import stdx/json::{JsonNode}

fn put(s: String) {
    auto fmt = String::from("%s")
    libc_printf(fmt.c_str(), s.c_str())
}

fn put_ptr(*s: String) {
    auto fmt = String::from("%s")
    libc_printf(fmt.c_str(), s.c_str())
}

fn print_json_node(val: JsonNode) {
    match val {
        NullNode(n) => { put(String::from("null")) }
        BoolNode(b) => { 
            if b { put(String::from("true")) } else { put(String::from("false")) }
        }
        NumNode(n) => { 
            auto num_str = String::from_f64(n)
            put(num_str) 
        }
        StrNode(&s) => {
            put(String::from("\""))
            put(s)
            put(String::from("\""))
        }
        ArrayNode(&arr_ptr) => {
            put(String::from("["))
            auto arr_iter# = arr_ptr.iter()
            auto first# = true
            while true {
                auto item_opt = arr_iter#.next()
                if item_opt.is_none() { break }
                auto item = item_opt.unwrap()
                print_json_node(item)
                first = false
            }
            put(String::from("]"))
        }
        ObjectNode(&map_ptr) => {
            put(String::from("{"))
            auto iter# = map_ptr#.iter()
            auto first# = true
            while true {
                auto entry_opt = iter#.next()
                if entry_opt.is_none() { break }
                auto entry = entry_opt.unwrap()
                if !first { put(String::from(", ")) }
                first = false
                put(String::from("\""))
                auto *k_ptr = entry.key()
                put_ptr(*k_ptr)
                put(String::from("\": "))
                auto *v_ptr = entry.val()
                print_json_node_ptr(*v_ptr)
            }
            put(String::from("}"))
        }
    }
}

fn print_json_node_ptr(*val_ptr: JsonNode) {
    match val_ptr {
        NullNode(n) => { put(String::from("null")) }
        BoolNode(b) => { 
            if b { put(String::from("true")) } else { put(String::from("false")) }
        }
        NumNode(n) => { 
            auto num_str = String::from_f64(n)
            put(num_str) 
        }
        StrNode(&s) => {
            put(String::from("\""))
            put(s)
            put(String::from("\""))
        }
        ArrayNode(&arr_ptr) => {
            put(String::from("["))
            auto arr_iter# = arr_ptr.iter()
            auto first# = true
            while true {
                auto item_opt = arr_iter#.next()
                if item_opt.is_none() { break }
                auto item = item_opt.unwrap()
                print_json_node(item)
                if !first { put(String::from(", ")) }
                first = false
            }
            put(String::from("]"))
        }
        ObjectNode(&map_ptr) => {
            put(String::from("{"))
            auto iter# = map_ptr#.iter()
            auto first# = true
            while true {
                auto entry_opt = iter#.next()
                if entry_opt.is_none() { break }
                auto entry = entry_opt.unwrap()
                if !first { put(String::from(", ")) }
                first = false
                put(String::from("\""))
                put_ptr(entry.key())
                put(String::from("\": "))
                print_json_node_ptr(entry.val())
            }
            put(String::from("}"))
        }
    }
}

pub fn main() -> i32 {
    auto json_str = String::from("{\"name\": \"Toka\", \"version\": 1.0, \"is_fast\": true, \"scores\": [100, 99.5], \"meta\": {\"type\": null}}")
    auto v_str = json_str.as_str()
    
    auto root#: JsonNode = JsonNode::NullNode(0)
    println("Starting parse...")
    auto parse_res = root#.parse_json(v_str)
    println("Finished parse!")
    
    if parse_res.is_err() {
        println("Parse failed")
        return 1
    }
    
    // Test match functionality over dynamic JSON Node!
    match root {
        ObjectNode(&map_ptr) => {
            println("Found root object!")
            
            println("--- Keys inside Object ---")
            auto iter# = map_ptr#.iter()
            while true {
                auto entry_opt = iter#.next()
                if entry_opt.is_none() { break }
                auto entry = entry_opt.unwrap()
                auto *key_p = entry.key()
                auto *val_p = entry.val()
                
                put_ptr(*key_p)
                put(String::from(": "))
                print_json_node_ptr(*val_p)
                put(String::from("\n"))
                // fflush stdout (null pointer to flush all)
                libc_fflush(null as *void)
            }
            println("--------------------------")
            
            // Check keys
            if map_ptr.get(String::from("name")).is_some() {
                println("Contains name!")
            }
        }
        _ => {
            println("Root is not object")
            return 1
        }
    }
    
    println("Successfully parsed and explored dynamic JsonNode!")
    return 0
}
