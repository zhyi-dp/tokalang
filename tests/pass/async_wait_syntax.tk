fn fetch() -> async str {
    "hello".await
    return "hello"
}

fn read_config() -> wait str {
    "config".wait
    return "config"
}

// pure caller is no longer passively infected; must explicitly suppress via spawn_blocking
fn pure_caller() {
    spawn_blocking(read_config())
}

pub fn main() -> i32 {
    spawn(fetch())
    pure_caller()
    return 0
}
