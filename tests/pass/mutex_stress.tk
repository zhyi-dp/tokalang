import std/sync::{Mutex}
import std/thread::{thread_spawn, yield_now}
import std/io::{println}

pub fn main() -> i32 {
    auto m# = Mutex<i32>::new(0)
    
    // We spawn 5 threads, each looping 1000 times, incrementing the protected value by 1 each time
    // The expected total sum should be 5000
    auto f: fn() -> cede i32 = { =>
        auto i# = 0
        while i < 1000 {
            auto g = m#.lock().unwrap()
            auto *p# = g.get_ref()
            
            // Perform computation after acquiring the lock
            auto current = p
            // Simulate a complex environment by yielding to increase race conditions
            if i % 10 == 0 {
                yield_now()
            }
            p = current + 1
            
            // The lock `g` will be automatically released by RAII at the end of the scope; do NOT call `m.unlock()` manually!
            i = i + 1
        }
        return cede 0
    }
    
    println("Spawning 5 threads to increment Mutex data 1000 times each...")

    auto t1# = thread_spawn<i32>(f)
    auto t2# = thread_spawn<i32>(f)
    auto t3# = thread_spawn<i32>(f)
    auto t4# = thread_spawn<i32>(f)
    auto t5# = thread_spawn<i32>(f)
    
    t1#.join().unwrap()
    t2#.join().unwrap()
    t3#.join().unwrap()
    t4#.join().unwrap()
    t5#.join().unwrap()
    
    auto final_lock = m#.lock().unwrap()
    auto *fp = final_lock.get_ref()
    
    println("All threads finished. Final Mutex data: {}", fp)
    
    // The final result must equal 5000
    if fp == 5000 {
        println("Stress test PASS! Mutex protected the data perfectly.")
        return 0
    }
    
    println("Stress test FAIL! Data race occurred.")
    return 1
}
