import std/io::println

shape Engine(
    val: i32
)

shape Node(
    val: i32,
    ~left: Engine,
    ~right: Engine,
    reads#: i32
)

shape Scene(
    ^root: Node
)

fn process_node(n: Node, val: i32) {
    // dummy function to consume a borrow and a value simultaneously
    println("processing node val {}, provided {}", n.val, val)
}

fn mutate_val(n#: Node) {
    n.val = 100
}

// Function with inline lifetime tying
fn select_engine(n1: Node, n2: Node) -> &Engine <- n1 | n2 {
    if n1.val > n2.val {
        return &(n1.left)
    }
    return &(n2.right)
}

// Function with effects block tying
fn select_engine_effects(n1: Node, n2: Node) -> &res: Engine
effects:
    &res <- n1 | n2
{
    if n1.right.val > n2.left.val {
        return &(n1.right)
    }
    return &(n2.left)
}

fn main() -> i32 {
    auto ~leftEngine = new Engine(val = 10)
    auto ~rightEngine = new Engine(val = 20)
    
    auto ^rootNode = new Node(val = 1, ~left = ~leftEngine, ~right = ~rightEngine, reads = 0)
    auto scene# = Scene(^root = ^rootNode)
    
    // 1. Transient Borrow check
    // Evaluates Transient for parameters seamlessly.
    process_node(scene.root, scene.root.val)
    
    // Following transient phase (end of Statement), locks are destroyed! We can mutate or re-borrow.
    scene.root.val = 2
    
    // 2. Lexical Scope locking
    {
        auto &my_root = scene.&root
        println("Locked root in inner scope, val={}", my_root.val)
        // If we mutated here, PAL would reject via E0442
    }
    
    // Out of scope, lexical ledger popped. Lock is gone.
    scene.root.val = 3
    
    // 3. Setup disjoint paths
    auto ~newLeft = new Engine(val = 100)
    auto ~newRight = new Engine(val = 200)
    
    scene.root.~left = ~newLeft
    scene.root.~right = ~newRight
    
    // Mutability on disjoint paths
    {
        // Mutably lock ONLY the left side
        auto &left_ref = &(scene.root.left)
        
        // Disjoint mutation on right side AND scalar shouldn't be blocked!
        scene.root.right.val = 30
        scene.root.val = 4
        
        println("left_ref val: {}", left_ref.val)
        println("right manipulated: {}", scene.root.right.val)
        assert(scene.root.right.val == 30, "disjoint mutation check")
    }

    // 4. Interior mutability on immutable active lock
    {
        auto &immut_ref = scene.&root
        // Immutable lock active via immut_ref!
        // We cannot write immut_ref.val = 55 (PAL E0443)
        // But we CAN write to #: fields (Interior Mutability)
        
        immut_ref.reads = immut_ref.reads + 1
        println("Reads successfully updated via immutable ref: {}", immut_ref.reads)
        assert(immut_ref.reads == 1, "Interior mutability failed")
    }

    // 5. Cross-Function Borrow Effects Testing
    {
        auto &heavy = select_engine(scene.root, scene.root)
        
        auto &heavy2 = select_engine_effects(scene.root, scene.root)
        
        // Both scene.root handles are securely locked as Immutable!
        // Writing to them via an active external tie would be rejected by PAL.
        // Uncommenting the below would be E0443 (Cannot modify immutable entity):
        // scene.root.val = 999 
    }

    println("PAL check completed brilliantly")
    return 0
}
