import std/io::{File, println}
import std/string::{String}
import core/str::{str, str}
import stdx/serde/json::{deserialize_shape}

pub shape SentryScope (
    _notifyingListeners: bool = false
)

pub fn main() -> i32 {
    auto path_str = String::from("./tests/pass/scope_v2.json")
    auto f# = File::open(path_str, "r")
    if !f.is_valid() {
        println("File not found")
        return 1
    }
    auto read_res = f.read_to_string()
    if read_res.is_err() {
        println("Read fail")
        return 1
    }
    auto json_str = read_res.unwrap()
    auto v_str = json_str.as_str()
    
    // Benchmarking loop (1000 parsing cycles)
    auto iter# = 0:i32
    loop iter < 1000 {
        auto p_res = deserialize_shape<SentryScope>(v_str)
        if p_res.is_err() {
            println("Parse err")
            return 1
        }
        iter += 1
    }
    
    println("Successfully validated Z-Copy Scanner Throughput!")
    return 0
}
