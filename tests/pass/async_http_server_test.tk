import std/io::{println}
import std/net_http::{HttpRequest, HttpResponse, HttpMethod, parse_http_request}
import std/net::{TcpListener, TcpStream, Ipv4Addr, SocketAddrV4, net_async_accept, net_async_read}
import std/string::{String}
import core/libc
import core/types
import core/result::{Result}
import std/task::{sleep_async, block_on}

// Basic handler router
fn handle_request(req#: HttpRequest) -> HttpResponse {
    auto is_get# = false
    match req.method {
           auto HttpMethod::GET => { is_get = true }
           _ => {}
    }
    
    auto is_home# = false
    if req.path.eq(String::from("/home")) { is_home = true }
    
    if is_get && is_home {
        auto res = HttpResponse::html(String::from("<h1>Welcome to Toka HTTP Framework</h1>"))
        return res
    }
    
    return HttpResponse::not_found()
}

fn process_client(stream: TcpStream) -> async i32 {
    unsafe {
        auto stream# = stream
        auto buf: [char; 1024] = [0 as char; 1024]
        auto *buf_ptr# = &buf[0] as *u8
        
        auto read_res = net_async_read(stream#, *buf_ptr, 1024:usize).await
        if read_res.is_err() {
            println("[Client Handler] Read error")
            return 1
        }
        
        auto n = read_res.unwrap()
        if n == 0:usize { return 0 }
        
        auto req_str = String::from_with_len(&buf[0] as *char, n as i32)
        auto req# = parse_http_request(req_str)
        
        // Pass to handler
        auto resp# = handle_request(req)
        auto resp_str = resp#.to_string()
        
        auto *ptr = resp_str.c_str() as *u8
        auto w_res = stream#.write_async(*ptr, resp_str.len() as usize).await
        
        // Let it close naturally to end server.
        stream#.close()
        return 0
    }
}

// Global flag to stop server
auto g_server_stop# = false

fn run_server(port: u16) -> async i32 {
    println("[Server] Binding to 127.0.0.1:{}...", port as i32)
    auto ip = Ipv4Addr::new(127:u8, 0:u8, 0:u8, 1:u8)
    auto addr = SocketAddrV4::new(ip, port)
    
    auto listener_res = TcpListener::bind(addr)
    if listener_res.is_err() { 
        println("[Server] Bind failed!")
        return 1 
    }
    auto listener# = listener_res.unwrap()
    println("[Server] Listening...")
    
    while !g_server_stop {
        auto stream_res = net_async_accept(listener#).await
        if stream_res.is_ok() {
            if g_server_stop { break } // exit before processing if stopped
            println("[Server] Accepted Web connection natively asynchronously!")
            auto stream = stream_res.unwrap()
            process_client(stream).start // detach child HTTP handler
        }
    }
    return 0
}

fn async_client_runner() -> async i32 {
    unsafe {
        sleep_async(50).await
        
        // Connect and send HTTP GET using connect_async
        auto ip = Ipv4Addr::new(127:u8, 0:u8, 0:u8, 1:u8)
        auto addr = SocketAddrV4::new(ip, 8901:u16)
        
        println("[Client] Connecting to Async Server...")
        auto connect_req = TcpStream::connect_async(addr)
        auto connect_res = connect_req.await
        if connect_res.is_err() { 
            println("[Client] connect failed")
            return 1 
        }
        
        auto stream# = connect_res.unwrap()
        
        auto req_line = String::from("GET /home HTTP/1.1\r\nHost: localhost:8901\r\nAccept: */*\r\n\r\n")
        auto write_res = stream#.write_string_async(req_line).await
        
        // Read response
        auto buf: [char; 1024] = [0 as char; 1024]
        auto *buf_ptr# = &buf[0] as *u8
        auto read_res = net_async_read(stream#, *buf_ptr, 1024:usize).await
        
        if read_res.is_ok() {
            auto n = read_res.unwrap()
            auto idx = n as i32
            auto *chr_ptr# = &buf[idx] as *char
            chr_ptr = 0 as char
            
            println("==========================================")
            println("[Client] HTTP Response received ({} bytes):", n as i32)
            println("==========================================")
            println("{}", &buf[0] as *char)
            println("==========================================")
        }
        
        stream#.close()
        g_server_stop = true // Signal server to stop
        
        // Push a dummy connection to wake up the accept loop so it discovers the stop flag
        auto finish_res = TcpStream::connect(addr)
        
        println("[Test] Web Server HTTP engine successful!")
        return 0
    }
}

fn entry_point() -> async i32 {
    run_server(8901:u16).start
    async_client_runner().await
    return 0
}

pub fn main() -> i32 {
    auto entry = entry_point().start
    block_on<i32>(entry#)
    return 0
}
