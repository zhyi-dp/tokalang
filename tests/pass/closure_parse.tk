fn test_closure(arg: i32) -> i32 {
    // 1. Implicit parameters
    auto f1 = { .a + 1 }
    
    // 2. Explicit cede capture with explicit parameters
    auto x = arg + 5
    auto f2 = [cede x] { y => y + x }
    
    // 3. Explicit copy capture with trailing closure 
    auto r = arg * 2
    auto val = 10
    // (We will just test assignment for now, no trailing until high-order functions exist)
    auto f3 = [copy ~r] { z => z + r }
    
    // 4. Multiple explicit parameters
    auto f4 = { a, b => a + b }
    
    // 5. Implicit return from block
    auto env = arg - 1
    auto f5 = [cede env] { 
        auto temp = .a + env
        temp // implicitly returned
    }
    
    return 0
}

fn main() -> i32 {
    test_closure(10)
    return 0
}
