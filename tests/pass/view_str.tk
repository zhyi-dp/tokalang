import std/io::println

fn test_view_str(vstr: view_str) -> i32 {
    // Test 1: Full slice clone
    auto full = vstr.clone()
    println("full: {}", full.raw_ptr())
    println("vstr: {}", vstr.raw_ptr())
    assert(full.equals(vstr), "FAIL: clone mismatch")

    // Test 2: Substr start
    auto s = vstr.substr(0, 5)
    assert(s.equals("hello"), "FAIL: prefix mismatch")

    // Test 3: starts_with / ends_with
    assert(vstr.starts_with("hello"), "FAIL: starts_with")
    assert(vstr.ends_with("toka!"), "FAIL: ends_with")
    assert(!vstr.starts_with("hella"), "FAIL: starts_with negative")
    assert(!vstr.ends_with("toba!"), "FAIL: ends_with negative")

    // Test 4: Char indexing
    auto c1 = vstr.at(0:usize)
    auto c2 = vstr.at(7:usize)
    assert(c1.unwrap() == 'h', "FAIL: at 0")
    assert(c2.unwrap() == 't', "FAIL: at 7")

    // Test 5: index_of
    auto i1 = vstr.index_of('o')
    auto i2 = vstr.last_index_of('o')
    assert(i1.unwrap() == 4:usize, "FAIL: index_of")
    assert(i2.unwrap() == 8:usize, "FAIL: last_index_of")
    assert(!vstr.index_of('z').is_some(), "FAIL: index_of negative")

    // Test 6: index_of_str
    auto str1 = vstr.index_of_str("toka")
    auto str2 = vstr.index_of_str("hello")
    auto str3 = vstr.index_of_str(",")
    assert(str1.unwrap() == 7:usize, "FAIL: index_of_str toka")
    assert(str2.unwrap() == 0:usize, "FAIL: index_of_str hello")
    assert(str3.unwrap() == 5:usize, "FAIL: index_of_str comma")
    assert(!vstr.index_of_str("toba").is_some(), "FAIL: index_of_str negative")

    check_trim("  hello  ", "hello", "FAIL: trim both ends")
    check_trim("   ", "", "FAIL: trim all whitespace")
    check_trim("hello world", "hello world", "FAIL: trim no whitespace")
    check_trim("\n\t hello \n", "hello", "FAIL: trim escape chars")

    return 0;
}

fn check_trim(s: str, expected: str, msg: str) {
    auto t = s.trim()
    assert(t.equals(expected), msg)
}

fn main() -> i32 {
    test_view_str("hello, toka!")    
    assert(true, "view_str tests passed successfully!")
    return 0
}