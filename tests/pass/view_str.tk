import std/io::println

fn test_view_str(vstr: view_str) -> i32 {
    // Test 1: Full slice clone
    auto full = vstr.clone()
    println("full: {}", full.raw_ptr())
    println("vstr: {}", vstr.raw_ptr())
    assert(full.equals(vstr), "FAIL: clone mismatch")

    // Test 2: Substr start
    auto s = vstr.substr(0, 5)
    assert(s.equals("hello"), "FAIL: prefix mismatch")

    // Test 3: starts_with / ends_with
    assert(vstr.starts_with("hello"), "FAIL: starts_with")
    assert(vstr.ends_with("toka!"), "FAIL: ends_with")
    assert(!vstr.starts_with("hella"), "FAIL: starts_with negative")
    assert(!vstr.ends_with("toba!"), "FAIL: ends_with negative")

    // Test 4: Char indexing
    auto c1 = vstr.at(0:usize)
    auto c2 = vstr.at(7:usize)
    assert(c1.unwrap() == 'h', "FAIL: at 0")
    assert(c2.unwrap() == 't', "FAIL: at 7")

    // Test 5: index_of
    auto i1 = vstr.index_of('o')
    auto i2 = vstr.last_index_of('o')
    assert(i1.unwrap() == 4:usize, "FAIL: index_of")
    assert(i2.unwrap() == 8:usize, "FAIL: last_index_of")
    assert(!vstr.index_of('z').is_some(), "FAIL: index_of negative")

    // Test 6: index_of_str
    auto str1 = vstr.index_of_str("toka")
    auto str2 = vstr.index_of_str("hello")
    auto str3 = vstr.index_of_str(",")
    assert(str1.unwrap() == 7:usize, "FAIL: index_of_str toka")
    assert(str2.unwrap() == 0:usize, "FAIL: index_of_str hello")
    assert(str3.unwrap() == 5:usize, "FAIL: index_of_str comma")
    assert(!vstr.index_of_str("toba").is_some(), "FAIL: index_of_str negative")

    check_trim("  hello  ", "hello", "FAIL: trim both ends")
    check_trim("   ", "", "FAIL: trim all whitespace")
    check_trim("hello world", "hello world", "FAIL: trim no whitespace")
    check_trim("\n\t hello \n", "hello", "FAIL: trim escape chars")

    test_split()
    test_lines()

    return 0;
}

fn get_str(s: str) -> str { return s.clone() }

fn test_split() {
    auto s1 = get_str("a,b,c")
    auto iter1# = s1.split(get_str(","))
    assert(iter1#.next().unwrap().equals(get_str("a")), "split 1.1")
    assert(iter1#.next().unwrap().equals(get_str("b")), "split 1.2")
    assert(iter1#.next().unwrap().equals(get_str("c")), "split 1.3")
    assert(iter1#.next().is_none(), "split 1.4")

    auto s2 = get_str("a::b::c")
    auto iter2# = s2.split(get_str("::"))
    assert(iter2#.next().unwrap().equals(get_str("a")), "split 2.1")
    assert(iter2#.next().unwrap().equals(get_str("b")), "split 2.2")
    assert(iter2#.next().unwrap().equals(get_str("c")), "split 2.3")
    assert(iter2#.next().is_none(), "split 2.4")

    auto s3 = get_str(",a,")
    auto iter3# = s3.split(get_str(","))
    assert(iter3#.next().unwrap().equals(get_str("")), "split 3.1")
    assert(iter3#.next().unwrap().equals(get_str("a")), "split 3.2")
    assert(iter3#.next().unwrap().equals(get_str("")), "split 3.3")
    assert(iter3#.next().is_none(), "split 3.4")

    auto s4 = get_str("a,,b")
    auto iter4# = s4.split(get_str(","))
    assert(iter4#.next().unwrap().equals(get_str("a")), "split 4.1")
    assert(iter4#.next().unwrap().equals(get_str("")), "split 4.2")
    assert(iter4#.next().unwrap().equals(get_str("b")), "split 4.3")
    assert(iter4#.next().is_none(), "split 4.4")

    auto s5 = get_str("abc")
    auto iter5# = s5.split(get_str(","))
    assert(iter5#.next().unwrap().equals(get_str("abc")), "split 5.1")
    assert(iter5#.next().is_none(), "split 5.2")

    auto s6 = get_str("")
    auto iter6# = s6.split(get_str(","))
    assert(iter6#.next().unwrap().equals(get_str("")), "split 6.1")
    assert(iter6#.next().is_none(), "split 6.2")
}

fn test_lines() {
    auto s1 = get_str("a\nb\nc")
    auto iter1# = s1.lines()
    assert(iter1#.next().unwrap().equals(get_str("a")), "lines 1.1")
    assert(iter1#.next().unwrap().equals(get_str("b")), "lines 1.2")
    assert(iter1#.next().unwrap().equals(get_str("c")), "lines 1.3")
    assert(iter1#.next().is_none(), "lines 1.4")

    auto s2 = get_str("a\n\nb\n\n")
    auto iter2# = s2.lines()
    assert(iter2#.next().unwrap().equals(get_str("a")), "lines 2.1")
    assert(iter2#.next().unwrap().equals(get_str("")), "lines 2.2")
    assert(iter2#.next().unwrap().equals(get_str("b")), "lines 2.3")
    assert(iter2#.next().unwrap().equals(get_str("")), "lines 2.4")
    assert(iter2#.next().unwrap().equals(get_str("")), "lines 2.5")
    assert(iter2#.next().is_none(), "lines 2.6")

    auto s3 = get_str("")
    auto iter3# = s3.lines()
    assert(iter3#.next().unwrap().equals(get_str("")), "lines 3.1")
    assert(iter3#.next().is_none(), "lines 3.2")
}

fn check_trim(s: str, expected: str, msg: str) {
    auto t = s.trim()
    assert(t.equals(expected), msg)
}

fn main() -> i32 {
    test_view_str("hello, toka!")    
    assert(true, "view_str tests passed successfully!")
    return 0
}