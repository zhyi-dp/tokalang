// tests/pass/build_hybrid_test.tk
// Integration test for FFI hybrid mixed building and linking.

import std/io::{File, println, remove_file}
import std/string::{String}
import sys/libc::{libc_system, libc_getenv}
import lib/build::{Executable, run_build}

fn main() -> i32 {
    println("Starting Build Hybrid integration test...")

    // 1. Write the dynamic C FFI file
    auto c_file# = File::open(String::from("tests/pass/temp_shim.c"), s"w")
    if !c_file.is_valid() {
        println("Failed to create temp_shim.c")
        return 1
    }
    c_file.write(s"extern \"C\" int get_magic_number() {\n    return 42;\n}\n")
    c_file#.close()

    // 2. Write the dynamic Toka main file
    auto tk_file# = File::open(String::from("tests/pass/temp_main.tk"), s"w")
    if !tk_file.is_valid() {
        println("Failed to create temp_main.tk")
        remove_file(String::from("tests/pass/temp_shim.c"))
        return 1
    }
    tk_file.write(s"import std/io::println\nextern fn get_magic_number() -> i32\nfn main() -> i32 {\n    auto val = get_magic_number()\n    println(\"Got value: {}\", val)\n    if val == 42 {\n        return 0\n    }\n    return 1\n}\n")
    tk_file#.close()

    // 3. Configure build project using our Executable FFI extensions
    auto proj# = Executable::make("temp_main" as *char, "tests/pass/temp_main.tk" as *char)
    proj#.add_c_src(String::from("tests/pass/temp_shim.c"))
    
    // 4. Run the build pipeline
    auto build_res = run_build(proj)
    if build_res != 0 {
        println("run_build failed with code: {}", build_res)
        remove_file(String::from("tests/pass/temp_shim.c"))
        remove_file(String::from("tests/pass/temp_main.tk"))
        return 1
    }

    // 5. Execute the compiled hybrid program and check its exit code
    auto is_windows# = false
    auto os_env = libc_getenv("OS" as *char) as Addr
    if os_env != 0:Addr {
        auto os_str = String::from(os_env as *char)
        if os_str == String::from("Windows_NT") {
            is_windows = true
        }
    }

    auto run_cmd# = String::from("")
    if is_windows {
        run_cmd = String::from("target\\debug\\temp_main ")
        run_cmd#.push_char(62:char)
        run_cmd#.push_str(" nul" as *char)
    } else {
        run_cmd = String::from("target/debug/temp_main ")
        run_cmd#.push_char(62:char)
        run_cmd#.push_str(" /dev/null" as *char)
    }

    auto run_res = libc_system(run_cmd.c_str())
    if run_res != 0 {
        println("Hybrid executable execution failed with code: {}", run_res)
        remove_file(String::from("tests/pass/temp_shim.c"))
        remove_file(String::from("tests/pass/temp_main.tk"))
        if is_windows {
            remove_file(String::from("target/debug/temp_main.exe"))
        } else {
            remove_file(String::from("target/debug/temp_main"))
        }
        return 1
    }

    println("Hybrid build integration test completed successfully!")

    // 6. Clean up temporary files
    remove_file(String::from("tests/pass/temp_shim.c"))
    remove_file(String::from("tests/pass/temp_main.tk"))
    if is_windows {
        remove_file(String::from("target/debug/temp_main.exe"))
    } else {
        remove_file(String::from("target/debug/temp_main"))
    }
    return 0
}
