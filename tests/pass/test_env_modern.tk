import std/env
import std/io::{println}

pub fn main() -> i32 {
    // Test args
    auto args = env::args()
    println("Args count: {}", args.len())
    if args.len() > 0 {
        println("First arg: {}", args.get_opt(0).unwrap())
    }
    
    // Test env var
    env::set_var(String::from("TOKA_TEST"), String::from("123"))
    auto val_opt = env::var(String::from("TOKA_TEST"))
    assert(val_opt.is_some(), "Env var not found")
    println("TOKA_TEST: {}", val_opt.unwrap())
    
    auto not_found = env::var(String::from("DOES_NOT_EXIST_12345"))
    assert(not_found.is_none(), "Non-existent env var found")
    
    // Test current_dir
    auto cwd = env::current_dir()
    println("CWD: {}", cwd)
    assert(cwd.len() > 0, "CWD is empty")
    
    println("Env tests passed!")
    return 0
}
