
import std/io::println

fn main() -> i32 {
    auto v = string::from("Chaining test").as_view()
    if v.len() != 13:usize {
        return 1
    }
    
    // Deeper chain
    auto l = string::from("Deep").as_view().len()
    if l != 4:usize {
        return 1
    }
    
    println("Chaining test passed!")
    return 0
}
