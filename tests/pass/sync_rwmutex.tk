import std/sync::{RwMutex, RwReadLock, RwWriteLock}
import std/io::println
import core/result::{Result}
import std/error::{Error}

fn main() -> i32 {
    auto rw# = RwMutex<i32>::new(42)

    println("Testing RwMutex read_lock...")
    {
        guard auto Ok(rl1) = rw#.read_lock() else {
            println("rw.read_lock 1 failed")
            return 1
        }
        
        guard auto Ok(rl2) = rw#.read_lock() else {
            println("rw.read_lock 2 failed (should allow concurrent readers)")
            return 1
        }
        
        auto *p1 = rl1.get_ref()
        auto *p2 = rl2.get_ref()
        
        println("Reader 1 sees: {}", p1)
        println("Reader 2 sees: {}", p2)
        
        if p1 != 42 {
            return 1
        }
    }
    
    println("Testing RwMutex write_lock...")
    {
        guard auto Ok(wl) = rw#.write_lock() else {
            println("rw.write_lock failed")
            return 1
        }
        
        auto *wp# = wl.get_ref()
        wp = 100
        println("Writer changed value to: {}", wp)
    }

    println("Verifying write_lock mutation via read_lock...")
    {
        guard auto Ok(rl) = rw#.read_lock() else {
            println("rw.read_lock failed")
            return 1
        }
        auto *p = rl.get_ref()
        println("Final value: {}", p)
        if p != 100 {
            return 1
        }
    }

    println("All RwMutex tests passed.")
    return 0
}
