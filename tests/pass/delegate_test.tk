

pub fn main() -> i32 {
    auto s# = string::from("")
    s#.push_str("Hello Delegate!")
    
    // Test the delegate trait fallback explicitly
    // byte_at is defined on str, not string.
    // If the intrinsic works, this will automatically resolve to s.target().byte_at(0)
    // let is deprecated in Toka, use auto
    auto first_char = s.byte_at(0)
    
    if first_char as i32 != 'H' as i32 {
        return 1
    }
    
    // length() is also on str!
    if s.len() != 15 {
        return 2
    }
    
    return 0
}
