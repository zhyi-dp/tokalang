// tests/pass/implicit_borrow_match.tk
import core/option::Option
import core/result::Result
import std/string::String
import std/io::println

// 1. Pure data destructuring test (Copy semantics)
shape Point(
    x: i32,
    y: i32
)

pub fn check_pure_data() {
    auto pt# = Point(x=10, y=20)
    
    // [Copy Semantics Verification]
    // Since Point does not encompass any @encap resources requiring Drop,
    // the '=' operator natively executes a by-value copy.
    // x and y become independent variables leaving their scope without burden.
    auto (x, y) = pt
    pt.x += 1
    println("pt.x = {}", pt.x)
    println("Point: x={}, y={}", x, y)
    assert(pt.x == 11, "pt.x should be 11")
    assert(x == 10, "x should be 10")

    {
        auto(&a,&b#) = pt#
        b += 1
        println("Point: a={}, b={}", a, b)
    }
    println("Point: pt.x={}, pt.y={}", pt.x, pt.y)
    assert(pt.x == 11, "pt.x should be 11")
    assert(pt.y == 21, "pt.y should be 21")
}

// 2. Resource-backed type destructuring test (Explicit Borrow semantics)
pub fn check_result(res: Result<String, String>) -> i32 {
    
    match res {
        // [Explicit Borrow Semantics Verification]
        // Because String carries an allocated resource (Drop), directly writing 
        // `auto Ok(msg)` is strictly forbidden (shallow copy of a resource).
        // Developers MUST explicitly wear the reference hat `&` to indicate:
        // "This is a read-only view; ownership is not transferred."
        auto Ok(&msg) => {
            println("Match read success: {}", msg.c_str())
        }
        auto Err(&e) => {
            println("Match error occurred: {}", e.c_str())
        }
    }

    // Guard destructuring must also follow the exact same borrow discipline:
    guard auto Ok(&guard_msg) = res else { 
        return 1 
    }

    // Safe and elegant reference usage:
    println("Guard read success: {}", guard_msg.len())

    return 0
}

pub fn main() -> i32 {
    check_pure_data()

    // string_res legitimately 'owns' this heap memory and the Result's lifecycle.
    auto string_res = Result<String, String>::Ok(String::from("Toka Destructure Safety"))

    // Invoke the destructuring exhibition
    check_result(string_res)

    // At the end of the main function, since string_res is the true owner,
    // its Drop will be uniquely and correctly executed.
    return 0
}
