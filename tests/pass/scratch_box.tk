import std/vec::Vec
import std/io::println

fn main() -> i32 {
    auto v1 = Vec<i32>::new()
    v1#.push(38)
    println("{}", v1.len())

    auto v2 = Vec<i32>(v1)
    println("{}", v2.len())

    auto ^v3 = new Vec<i32>(cede v2)    
    println("{},{}", v3.len(),v3.at(0))

    println("{},{}", v1.len(),v1.at(0))
    //println("{},{}", v2.len(),v2.at(0))
    
    return 0
}
