import std/hash_map::{HashMap}
import std/string::{string}
import std/io::{println}
import sys/libc::{libc_printf}

fn test_robin_hood() {
    auto map# = HashMap<i32, string>::new()
    
    // 1. Heavy insertion to trigger resizes and Robin Hood stealing
    auto i# = 0
    loop i < 1000 {
        auto val_str# = string::from("val_")
        map#.insert(i, cede val_str)
        i += 1
    }
    
    // Validate length
    if map.len() != 1000 {
        unsafe { libc_printf(c"FAIL: len should be 1000, got %d\n", map.len() as i32) }
        return
    }
    
    // 2. Validate gets
    auto j# = 0
    loop j < 1000 {
        auto opt = map.get(j)
        if opt.is_none() {
            unsafe { libc_printf(c"FAIL: could not get %d\n", j) }
            return
        }
        j += 1
    }
    
    // 3. Heavy backward shift deletion
    auto k# = 0
    loop k < 1000 {
        auto rm_opt = map#.remove(k)
        if rm_opt.is_none() {
            unsafe { libc_printf(c"FAIL: could not remove %d\n", k) }
            return
        }
        k += 2
    }
    
    if map.len() != 500 {
        unsafe { libc_printf(c"FAIL: len should be 500, got %d\n", map.len() as i32) }
        return
    }
    
    // 4. Overwrite existing
    map#.insert(1, string::from("val_1_new"))
    auto opt3 = map.get(1)
    if opt3.is_none() {
        unsafe { libc_printf(c"FAIL: replace failed\n") }
        return
    }
    
    println("HashMap Robin Hood works perfectly!")
}

pub fn main() -> i32 {
    test_robin_hood()
    return 0
}
