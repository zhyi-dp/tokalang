import stdx/cli/flag::{Parser, ParsedArgs}
import std/vec::{Vec}

import core/result::{Result}
import std/io::{println}

fn main() -> i32 {
    auto parser = Parser::new(string::from("test-server"), string::from("A test server"))
    parser#.add_int(string::from("port"), 'p', 8080, string::from("Port to listen on"))
    parser#.add_bool(string::from("verbose"), 'v', false, string::from("Enable verbose output"))
    parser#.add_float(string::from("timeout"), 't', 30.0, string::from("Timeout in seconds"))
    parser#.add_string(string::from("config"), 'c', string::from("config.toml"), string::from("Config file path"))

    auto args# = Vec<string>::new()
    args#.push(string::from("test-server")) // argv[0]
    args#.push(string::from("-p"))
    args#.push(string::from("9090"))
    args#.push(string::from("--verbose"))
    args#.push(string::from("--timeout=2.5"))
    args#.push(string::from("--config=custom.toml"))
    args#.push(string::from("start"))
    args#.push(string::from("web"))

    auto res = parser.parse(args)
    
    if res.is_err() {
        auto err_msg# = string::from("Parse failed: ")
        err_msg#.push_str(res.unwrap_err().as_str())
        println("{}", err_msg.c_str())
        return 1
    }
    auto parsed_args = res.unwrap()

    auto port = parsed_args.get_int(string::from("port"))
    if port != 9090 {
        println("port assertion failed")
        return 1
    }

    auto verbose = parsed_args.get_bool(string::from("verbose"))
    if !verbose {
        println("verbose assertion failed")
        return 1
    }

    auto timeout = parsed_args.get_float(string::from("timeout"))
    if timeout != 2.5 {
        println("timeout assertion failed")
        return 1
    }

    auto config = parsed_args.get_string(string::from("config"))
    if config != string::from("custom.toml") {
        println("config assertion failed")
        return 1
    }

    auto pos = parsed_args.positionals()
    if pos.len() != 2:usize || pos.get(0) != string::from("start") || pos.get(1) != string::from("web") {
        println("positionals assertion failed")
        return 1
    }

    println("All tests passed!")
    return 0
}
