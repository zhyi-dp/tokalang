// test_token_paths.tk
// 验证精确的内存路径交叠（Overlapping）冲突检测

shape Child(
    x: i32,
    y: i32
)

shape Parent(
    c1: Child,
    c2: Child,
    flag: bool
)

fn main() -> i32 {
    auto p# = Parent(
        c1=Child(x=10, y=20),
        c2=Child(x=30, y=40),
        flag=true
    )

    // 测试 1：正交路径的共享与可变借用不会冲突
    auto &x_ref = p.c1.&x
    auto &y_mut# = p.c1.&y 
    y_mut = 99 // 修改 Soul (内容)
    
    // 测试 2：跨树枝的安全可变借用
    auto &c2_ptr# = p.&c2
    c2_ptr.x = 31 // 自动解引用访问的内容

    // 测试 3（预期失败）：同路径下的子树冲突
    // 如果在这里尝试借用 p.c1 会报错，因为 p.c1.x 和 p.c1.y 已经被借出
    // auto #c1_mut = p.c1 // [Compile Error Expected]: p.c1 is partially borrowed
    
    // 测试 4（预期失败）：别名重叠冲突
    // auto #x_mut_again = p.c1.x // [Compile Error Expected]: p.c1.x is already borrowed immutably
    
    if (x_ref == 10 && p.flag) {
        return 0
    }
    return 1
}
