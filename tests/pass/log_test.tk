import stdx/log/log::{Logger, LOG_DEBUG, LOG_INFO, LOG_WARN, LOG_ERROR, debug, info, warn, error}
import std/string::{string}
import std/io::{print_line}

pub fn main() -> i32 {
    print_line(string::from("--- Testing Global Convenience Functions ---"))
    debug(string::from("This is a debug message (visible)"))
    info(string::from("This is an info message"))
    warn(string::from("This is a warning message"))
    error(string::from("This is an error message"))

    print_line(string::from("\n--- Testing Configured Logger ---"))
    auto logger# = Logger::new(LOG_WARN)
    
    // Debug and info should NOT print since level is WARN
    logger#.debug(string::from("This should NOT print (debug)"))
    logger#.info(string::from("This should NOT print (info)"))
    
    // Warn and error SHOULD print
    logger#.warn(string::from("This should print (warn)"))
    logger#.error(string::from("This should print (error)"))
    return 0
}
