
fn simple_life(a: i32) -> &i32 <- a {
    return &a
}

fn tuple_life(a: i32, b: i32) -> res: (first: &i32, second: &i32)
effects:
    res.first <- a
    res.second <- b
{
    return (first = &a, second = &b)
}

fn main() -> i32 {
    auto x = 10
    auto &y = simple_life(x)
    if (y != 10) return 1

    auto z = 20
    auto t = tuple_life(x, z)
    // t is (first: &i32, second: &i32). t.first is &i32.
    // Auto-deref should work for record members if they are refs?
    // Let's test explicit deref if needed, or implicit.
    // Based on previous simple_life, 'y' (ref) auto-derefs.
    // 't.first' is an access expression returning a reference.
    // So 't.first' should evaluate to i32 value.
    auto &v1 = t.&first
    auto &v2 = t.&second
    if (v1 != 10) return 2
    if (v2 != 20) return 3
    
    return 0
}
