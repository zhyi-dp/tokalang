import std/io::println
import core/types::OAddr

shape Point(
    *x: i32
)
impl Point {
    pub fn clone(self) -> Point {
        return Point(*x = self.*x)
    }
    fn drop(self#) {}
}

pub fn main() -> i32 {
    auto a# = 42
    auto *raw_ptr = *a
    auto &ref = &a

    // 1. Raw pointer direct printing and casting
    println("raw direct: {}", *raw_ptr)
    println("raw with as: {}", *raw_ptr as OAddr)

    // 2. Reference direct printing and casting
    println("ref direct: {}", &ref)
    println("ref with as: {}", &ref as OAddr)

    // 3. Unique pointer (cast to OAddr first, then direct print to verify move semantics)
    auto ^uniq = new Point(*x = *a)
    println("uniq with as: {}", ^uniq as OAddr)
    println("uniq direct after move: {}", ^uniq)

    // 4. Shared pointer direct printing and casting (no ownership transfer/move-to-zero semantics)
    auto ~shared = new Point(*x = *a)
    println("shared direct: {}", ~shared)
    println("shared with as: {}", ~shared as OAddr)

    return 0
}
