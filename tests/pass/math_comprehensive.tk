import std/math::{PI, PI32, fsin, fsin32, fsqrt, fsqrt32, abs, gcd, lerp}
import std/io::{println}

fn main() -> i32 {
    println("--- Math Library Test (Explicit Precision) ---")

    // 1. Double Precision (f64)
    assert(fsin(PI() / 2.0) == 1.0, "fsin(f64)")
    assert(fsqrt(16.0) == 4.0, "fsqrt(f64)")

    // 2. Single Precision (f32)
    assert(fsin32(PI32() / 2.0:f32) == 1.0:f32, "fsin32(f32)")
    assert(fsqrt32(16.0:f32) == 4.0:f32, "fsqrt32(f32)")

    // 3. Generic Tools
    assert(lerp(0.0, 10.0, 0.5) == 5.0, "lerp(f64)")
    assert(lerp(0.0:f32, 10.0:f32, 0.5:f32) == 5.0:f32, "lerp(f32)")

    // 4. Integers
    assert(gcd(48, 18) == 6, "gcd(i32)")
    assert(abs(0 - 100) == 100, "abs(i32)")

    println("All Explicit Precision Math Tests Passed!")
    return 0
}
