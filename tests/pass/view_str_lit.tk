import std/io::println
import core/str::str

fn main() -> i32 {
    auto s = s"Hello Toka"
    println("{}", s)
    
    if s.len() != 10:usize {
        return 1
    }
    
    // Check if it's really a str by passing to a function expecting it
    check_view(s)
    
    return 0
}

fn check_view(v: str) {
    if v.len() > 0:usize {
        println("Checked str successfully")
    }
}
