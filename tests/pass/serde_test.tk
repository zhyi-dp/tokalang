import stdx/serde/json::{JsonNode, to_json, deserialize_shape, ToJson, serialize_shape}
import std/string::{string}
import std/io::{println}
import std/vec::{Vec}
import core/result::{Result}
import core/str::{str}

shape User(
    id: i32 = 0,
    name: string = string::from(""),
    active: bool = false,
    tags#: Vec<string> = Vec<string>::new(),
    email: Option<string> = Option<string>::None,
    status: Result<i32, string> = Result<i32, string>::Ok(0)
)

impl User@ToJson {
    pub fn write_json(self, buf#: string) -> string {
        return serialize_shape(self, buf)
    }
}

fn main() -> i32 {
    auto u# = User(
        id = 1,
        name = string::from("Alice"),
        active = true,
        tags = Vec<string>::new(),
        email = Option<string>::Some(string::from("alice@example.com")),
        status = Result<i32, string>::Err(string::from("Offline"))
    )
    
    u.tags#.push(string::from("rust"))
    u.tags#.push(string::from("toka"))
    
    auto json = to_json(u)
    println("JSON: {}", json.as_view())
    
    // Test deserialization
    auto u_res = deserialize_shape<User>(json.as_view())
    match u_res {
        auto Result<User, str>::Ok(u2) => {
            println("Deserialized ID: {}", u2.id)
            println("Deserialized Name: {}", u2.name)
            println("Deserialized Tags len: {}", u2.tags.len() as i32)
            match u2.email {
                auto Option<string>::Some(&e) => println("Deserialized Email: {}", e.as_view())
                _ => println("Deserialized Email: None")
            }
            match u2.status {
                auto Result<i32, string>::Err(&e) => println("Deserialized Status: Err({})", e.as_view())
                _ => println("Deserialized Status: Ok")
            }
        }
        auto Result<User, str>::Err(&e) => {
            println("Deserialization failed: {}", e)
            return 1
        }
    }
    
    return 0
}
