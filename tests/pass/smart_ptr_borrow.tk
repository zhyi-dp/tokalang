

import std/io::*

fn main() -> i32 {
    // Unique Pointer Test
    {
        auto ^p = new i32(100)
        println("A"); println("p: {}", p)
        {
            // Key action: borrow occurs
            // Physical process: &p is actually &p (dereferenced/Value). Reference x points to data directly.
            // Legal process: Compiler marks p with [FROZEN] attribute.
            auto &x = &p 
            
            println("B"); println("Borrowed unique: {}", x)
            if x != 100 {
                println("Assertion failed: x should be 100")
                return 1
            }
            
            // Attempting to move p here (e.g. auto ^k = ^p) must trigger a compiler error.
            // This mirrors Rust's "cannot move out of ... because it is borrowed"
        } 
        // Borrow ends, x is destroyed.
        // Legal process: p's [FROZEN] attribute is removed.
        
        // Legal Move
        // Note: ^p in rvalue position explicitly denotes a Move, which is crystal clear!
        println("C"); auto ^q = ^p 
    }

    // Shared Pointer Test
    {
        auto ~#s# = new i32(200) // Mutable variable s
        {
            auto &y = &s
            println("D"); println("Borrowed shared: {}", y)
            // s cannot be mutated here
        }
        s = 250
        ~s = new i32(300) // Rebind shared pointer to new object
    }
    
    return 0
}
