import std/io::println

fn main() -> i32 {
    // ---------------------------------------------------
    // Step 1: Source Definitions
    // ---------------------------------------------------
    // Crucial correction: in order for ptr to modify them, both arr1 and arr2 must be writable (#)!
    auto arr1# = [10, 20]
    auto arr2# = [99, 88] // If there is no # here, `auto *#ptr# = *arr1` below will cause a compile error because soul mutability cannot be changed arbitrarily

    unsafe {
        // ---------------------------------------------------
        // Step 2: Declare Double Mutable Pointer (The Double Agent)
        // ---------------------------------------------------
        // auto *#ptr#
        //  *# : Identity is Swappable (pointer itself is mutable, can point to others)
        //  ptr# : Soul is Writable (pointed content is mutable, can change value)
        // Right side: Get address from arr1. Compiler will check if arr1 has # permission.
        auto *#ptr# = *arr1 as *[i32]
        
        // ---------------------------------------------------
        // Scenario A: Mutate Value (Soul)
        // ---------------------------------------------------
        // Rule: To modify the value, # must be presented at the end of the access path
        
        ptr[0] = 30         // OK: modify ptr[0]. Semantics: Access Soul -> Write.
        
        // Semantics: Offset to 1 -> Access Soul -> Write.
        ptr[1] = 40      
        
        assert(arr1[0] == 30, "arr1[0] should be 30")
        assert(arr1[1] == 40, "arr1[1] should be 40")

        // ---------------------------------------------------
        // Scenario B: Rebind Identity
        // ---------------------------------------------------
        // Rule: To modify the target, must present # after *
        // ptr# is not needed here because we are changing the address, not the value.
        
        *ptr = *arr2 as *[i32]     // OK: Pointer redirected! Points to arr2
        
        // ---------------------------------------------------
        // Scenario C: Exercising Power on the New Address
        // ---------------------------------------------------
        // Verify identity change
        assert(ptr[0] == 99, "ptr[0] should be 99") // ptr[0] is now arr2[0]
        
        // Continue modifying soul (because ptr# still has write permission, and arr2# allows writing)
        ptr[0] = 100        // OK: modify arr2[0]
        assert(arr2[0] == 100, "arr2[0] should be 100")
    }
    return 0
}