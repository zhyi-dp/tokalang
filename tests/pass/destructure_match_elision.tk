import std/io::println

shape Point(x: i32, y: i32, z: i32)
shape Pair(v0: i32, v1: i32, v2: i32)

shape ASTNode(
    BinaryExpr(i32, i32, i32) |
    UnaryExpr(i32)
)

fn test_struct_destruct() -> i32 {
    auto p = Point(x = 10, y = 20, z = 30)
    auto Point(a = .x, c = .z, ..) = p
    if a != 10 || c != 30 {
        return 1
    }
    return 0
}

fn test_tuple_destruct() -> i32 {
    auto t = Pair(v0 = 100, v1 = 200, v2 = 300)
    auto Pair(a = .v0, c = .v2, ..) = t
    if a != 100 || c != 300 {
        return 2
    }
    return 0
}

fn test_match_struct() -> i32 {
    auto p = Point(x = 1, y = 2, z = 3)
    auto val = match p {
        Point(1 = .x, 3 = .z, ..) => {
            pass 0
        }
        default => {
            pass 99
        }
    }
    return val
}

fn test_match_enum() -> i32 {
    auto node = ASTNode::BinaryExpr(10, 20, 30)
    auto val = match node {
        ASTNode::BinaryExpr(10, .., 30) => {
            pass 0
        }
        default => {
            pass 99
        }
    }
    return val
}

fn test_wildcard_underscore() -> i32 {
    auto p = Point(x = 5, y = 15, z = 25)
    
    // 1. Test single underscore in destructuring
    auto Point(a = .x, _ = .y, c = .z) = p
    if a != 5 || c != 25 {
        return 1
    }

    // 2. Test multiple underscores in destructuring
    auto Point(x = .x, _ = .y, _ = .z) = p
    if x != 5 {
        return 2
    }

    // 3. Test underscore in match structural pattern
    auto val = match p {
        Point(5 = .x, _ = .y, 25 = .z) => {
            pass 0
        }
        default => {
            pass 99
        }
    }
    if val != 0 {
        return 3
    }

    return 0
}

fn main() -> i32 {
    if test_struct_destruct() != 0 {
        println("test_struct_destruct failed")
        return 1
    }
    if test_tuple_destruct() != 0 {
        println("test_tuple_destruct failed")
        return 2
    }
    if test_match_struct() != 0 {
        println("test_match_struct failed")
        return 3
    }
    if test_match_enum() != 0 {
        println("test_match_enum failed")
        return 4
    }
    if test_wildcard_underscore() != 0 {
        println("test_wildcard_underscore failed")
        return 5
    }
    println("All pass tests succeeded")
    return 0
}
