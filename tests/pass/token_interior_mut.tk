// token_interior_mut.tk
// Verification for zero-cost interior mutability (#:)

shape CounterInfo(
    accesses#: i32, // Zero-cost interior mutability, pure value type
    name: cstring
)

fn process_info(info: CounterInfo) {
    // Even if info is borrowed, we allow direct overwrite on fields decorated with #:
    info.accesses = info.accesses + 1
    
    // Core iron law: derivation of any borrow tokens from #: fields is strictly prohibited
    // If the following two lines are uncommented, a compilation error should be triggered
    // auto &acc_ref = info.&accesses  // [Compile Error Expected]
    // auto &acc_mut# = info.&accesses  // [Compile Error Expected]
    
    // Borrowing regular fields is unaffected
    auto &name_ref = info.&name
}

fn main() -> i32 {
    auto c = CounterInfo(accesses=0, name="metrics")
    process_info(c)
    process_info(c)
    
    if (c.accesses == 2) {
        return 0
    }
    return 1
}
