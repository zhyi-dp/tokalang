import std/slab::{Slab, SlabID}
import std/io::{println}
import core/option::{Option}

shape Entity (
    name: string,
    val: i32
)

fn main() -> i32 {
    auto slab# = Slab<Entity>::new()
    
    // 1. Insert elements
    auto id1 = slab#.insert(Entity(name=string::from("alpha"), val=10))
    auto id2 = slab#.insert(Entity(name=string::from("beta"), val=20))
    
    println("id1 index: {}, generation: {}", id1.index() as i64, id1.generation() as i64)
    println("id2 index: {}, generation: {}", id2.index() as i64, id2.generation() as i64)
        
    assert(id1.index() == 0, "first index should be 0")
    assert(id1.generation() == 1, "first generation should be 1")
    assert(id2.index() == 1, "second index should be 1")
    assert(id2.generation() == 1, "second generation should be 1")
    
    // 2. Retrieve elements
    auto e1_opt = slab.get(id1)
    assert(e1_opt.is_some(), "should retrieve id1")
    auto e1 = e1_opt.unwrap()
    assert(e1.val == 10, "value should be 10")
    
    // 3. Remove an element and check slot reuse
    auto removed_e1 = slab#.remove(id1).unwrap()
    assert(removed_e1.val == 10, "removed value should be 10")
    
    // 4. Retrieve after removal should fail
    assert(slab.get(id1).is_none(), "should fail to retrieve removed element")
    
    // 5. Insert new element - should reuse Slot 0 and increment generation
    auto id3 = slab#.insert(Entity(name=string::from("gamma"), val=30))
    println("id3 index: {}, generation: {}", id3.index() as i64, id3.generation() as i64)
        
    assert(id3.index() == 0, "should reuse Slot 0")
    assert(id3.generation() == 2, "generation should increment to 2 to prevent ABA")
    
    // 6. Accessing Slot 0 with old id1 should fail due to generational check!
    assert(slab.get(id1).is_none(), "generational ID should prevent ABA stale read")
    
    auto e3 = slab.get(id3).unwrap()
    assert(e3.val == 30, "reused slot should have new value 30")
    
    println("Generational Slab test passed successfully!")
    return 0
}
