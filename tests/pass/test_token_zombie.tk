// test_token_zombie.tk
// 验证强更新时的强制吊销机制（Zombie Revocation）

shape SelfRef(
    name: str,
    &ref: str <- &name  // 自引用，ref 的借用令牌依赖于 name
)

fn main() -> i32 {
    auto obj# = SelfRef(name="hello")
    obj.&ref = obj.&name // 建立内部依赖

    // ... 此时通过 obj.ref 读取是合法的
    
    // 强更新：覆写了被依赖的源路径（obj.name）
    // 按照机制，这时候不会报错“已有借用被锁定”，而是静默发生“强制吊销”
    // 原来的 obj.ref 持有的借用令牌会变成 IsZombie = true
    obj.name = "world"

    // 测试（预期失败）：如果后续尝试读取变成了僵尸的令牌，应当在编译期报错
    // 这里如果我们尝试读取或解引用 obj.ref：
    // return obj.ref.len() // [Compile Error Expected]: Access to revoked (Zombie) token
    
    // 正确的处理方式必须是开发者重新绑定令牌，洗刷僵尸状态：
    obj.&ref = obj.&name 
    
    return 0
}
