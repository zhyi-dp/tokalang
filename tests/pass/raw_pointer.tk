import std/io::println
import std/memory

shape Hero (
    id: i32,
    hp: i32
)

fn main() -> i32 {
    // 1. Heap Allocation & Initialization (Scalar Heap Alloc)
    // According to 1.1: alloc i32(42)
    auto *p = unsafe alloc i32(42)
    
    unsafe {
        // According to 4: access must be through dereference, p represents the entity value
        println("Scalar Value: {} (expected 42)", p)
        assert(p == 42, "p mismatch")
        println("Address: {}", *p)
        
        // According to 7: manual free
        free *p
    }

    // 2. Array Allocation & Arithmetic (Array Alloc & Stride)
    // According to 1.2: alloc [5]i32(0) maps to memset 0
    auto *arr# = (unsafe alloc [5]i32(0)) as *[i32]
    unsafe {
        arr[0] = 10
        arr[1] = 20
        
        // According to 5: Track B - Item Stride
        // *arr[1] gets the address of the second element
        auto *p_second = *arr[1] as *[i32]
        println("Stride Access: {} (expected 20)", p_second[0])
        
        // According to 5: Track A - Byte Offset
        // *arr + 4 offsets by 4 bytes (i.e., width of an i32)
        auto *p_offset = (*arr + 4) as *[i16]
        println("Byte Offset Access: {} (expected 20)", p_offset[0])
        assert(p_second[0] == 20, "stride mismatch")
        // No assert for p_offset[0] as i16 logic complex to verify in token
        
        free *arr
    }

    // 3. Struct Access (Struct Access)
    unsafe {
        // According to 1.3: struct allocation
        auto *h# = alloc Hero(id = 7, hp = 100)
        // According to 4: direct member access
        println("Hero ID: {} (expected 7)", h.id)
        
        h.hp = 80
        println("Hero HP: {} (expected 80)", h.hp)
        assert(h.id == 7, "h.id mismatch")
        assert(h.hp == 80, "h.hp mismatch")
        
        free *h
    }

    // 4. Stack Address Acquisition (Stack Address)
    // According to 3: *variable gets the stack address, belongs to SAFE
    auto stack_val = 123:i32
    auto *p_stack# = *stack_val as *[i32]
    
    unsafe {
        p_stack[0] = 456
        println("Stack Modified: {} (expected 456)", stack_val)
        assert(stack_val == 456, "stack_val mismatch")
    }

    // 5. Permission Management (Permissions)
    // According to 8: allow permission upgrade (Trust the Human)
    auto val = 1:i32
    auto *px = *val as *[i32]
    auto *px_mut# = *px // Permission Upgrade: Const -> Mut
    
    unsafe {
        px_mut[0] = 2
        println("Permission Upgrade: val={} (expected 2)", val)
        assert(val == 2, "val mismatch after upgrade")
    }

    // 6. Null Check (Null Check)
    // According to 7: *ptr == null belongs to SAFE
    auto nul *empty:Hero = null
    if null == *empty {
        println("Null pointer confirmed")
        assert(true, "Null pointer check passed")
    }

    return 0
}