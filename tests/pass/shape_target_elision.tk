import std/io::println

extern fn strcmp(s1: cstring, s2: cstring) -> i32

shape Person(
    name: cstring = "Anonymous",
    age: i32 = 18,
    score: f32 = 0.0 as f32
)

fn main() -> i32 {
    // 1. Named elision: Person(age = 25, score = 100.0 as f32, ..) -> name gets default "Anonymous"
    auto p1 = Person(age = 25, score = 100.0 as f32, ..)
    println("p1: name: {}, age: {}, score: {}", p1.name, p1.age, p1.score)

    // 2. Named elision at the end: Person(name = "Alice", ..) -> age gets 18, score gets 0.0
    auto p2 = Person(name = "Alice", ..)
    println("p2: name: {}, age: {}, score: {}", p2.name, p2.age, p2.score)

    // 3. Named elision with .. at the beginning: Person(.., score = 88.0)
    auto p3 = Person(.., score = 88.0 as f32)
    println("p3: name: {}, age: {}, score: {}", p3.name, p3.age, p3.score)

    // 4. Named elision with .. in the middle: Person(name = "Bob", .., score = 99.0)
    auto p4 = Person(name = "Bob", .., score = 99.0 as f32)
    println("p4: name: {}, age: {}, score: {}", p4.name, p4.age, p4.score)

    // 5. Named elision with .. at the end: Person(name = "Charlie", age = 30, ..)
    auto p5 = Person(name = "Charlie", age = 30, ..)
    println("p5: name: {}, age: {}, score: {}", p5.name, p5.age, p5.score)

    // Assertions
    if strcmp(p1.name, "Anonymous") != 0 || p1.age != 25 || p1.score != 100.0 as f32 { return 1 }
    if strcmp(p2.name, "Alice") != 0 || p2.age != 18 || p2.score != 0.0 as f32 { return 1 }
    if strcmp(p3.name, "Anonymous") != 0 || p3.age != 18 || p3.score != 88.0 as f32 { return 1 }
    if strcmp(p4.name, "Bob") != 0 || p4.age != 18 || p4.score != 99.0 as f32 { return 1 }
    if strcmp(p5.name, "Charlie") != 0 || p5.age != 30 || p5.score != 0.0 as f32 { return 1 }

    return 0
}
