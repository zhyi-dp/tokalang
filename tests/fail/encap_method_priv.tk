fn main() {
    auto s = string::from("Secret")
    // drop is defined as `fn drop(self#)` inside `impl string@encap`, WITHOUT `pub`.
    // It should be private to the module/file defining it.
    // This call should fail compilation.
    s.drop()
    // EXPECT: error[E0437]:
}
