import core/result::{Result, Result}
import std/string::string
import std/io::println

fn test() -> Result<string, string> {
    auto r = Result<string, string>::Ok(string::from("hello"))
    auto v = r!
    // EXPECT: use of moved variable
    auto z = r
    return Result<string, string>::Ok(v)
}

pub fn main() -> i32 { 
    auto res = test()
    println("{}", res.unwrap())
    return 0 
}
