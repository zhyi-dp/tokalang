import std/io::{println}
import src/lexer::{Lexer}
import src/token

fn main() -> i32 {
    auto lexer# = Lexer::new("fn main()->i32{ auto x=10 }".clone())
    while !lexer.is_eof() {
        auto t = lexer#.next_token()
        if t.kind == token::TK_EOF() { break }
        println(t.lexeme.clone())
    }
    return 0
}
