// lib/std/atomic.tk
// High-level safe abstractions over LLVM atomic intrinsics.

import core/intrinsics/atomic as core_atomic
pub import core/intrinsics/atomic::Ordering

// ==========================================
// AtomicI32
// ==========================================

pub shape AtomicI32 (
    val#: i32
)

impl AtomicI32@Send {}
impl AtomicI32@Sync {}

impl AtomicI32 {
    pub fn new(v: i32) -> AtomicI32 {
        return AtomicI32(val = v)
    }

    pub fn make(v: i32) -> ^AtomicI32 {
        return new AtomicI32(val = v)
    }

    pub fn load(self, order: Ordering) -> i32 {
        return core_atomic::__toka_atomic_load(self.val#, order)
    }

    pub fn store(self, v: i32, order: Ordering) {
        core_atomic::__toka_atomic_store(self.val#, v, order)
    }

    pub fn swap(self, v: i32, order: Ordering) -> i32 {
        return core_atomic::__toka_atomic_swap(self.val#, v, order)
    }

    pub fn compare_exchange(
        self, current: i32, new_val: i32, success: Ordering, failure: Ordering
    ) -> (i32, bool) {
        return core_atomic::__toka_atomic_compare_exchange(
            self.val#, current, new_val, success, failure
        )
    }

    pub fn fetch_add(self, v: i32, order: Ordering) -> i32 {
        return core_atomic::__toka_atomic_fetch_add(self.val#, v, order)
    }

    pub fn fetch_sub(self, v: i32, order: Ordering) -> i32 {
        return core_atomic::__toka_atomic_fetch_sub(self.val#, v, order)
    }

    pub fn fetch_and(self, v: i32, order: Ordering) -> i32 {
        return core_atomic::__toka_atomic_fetch_and(self.val#, v, order)
    }

    pub fn fetch_or(self, v: i32, order: Ordering) -> i32 {
        return core_atomic::__toka_atomic_fetch_or(self.val#, v, order)
    }

    pub fn fetch_xor(self, v: i32, order: Ordering) -> i32 {
        return core_atomic::__toka_atomic_fetch_xor(self.val#, v, order)
    }
}


