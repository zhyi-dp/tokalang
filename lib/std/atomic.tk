// ==========================================
// AtomicBool
// ==========================================
// Note: LLVM requires atomic ops to act on integer types mapping 1:1, usually i8 for bool.
// Toka's bool natively maps to i1. We wrap it around.

pub shape AtomicBool (
    val#: i32
)

impl AtomicBool@Send {}
impl AtomicBool@Sync {}

impl AtomicBool {
    pub fn new(v: bool) -> AtomicBool {
        auto b_val# = 0
        if v { b_val = 1 }
        return AtomicBool(val = b_val)
    }

    pub fn make(v: bool) -> ^AtomicBool {
        auto b_val# = 0
        if v { b_val = 1 }
        return new AtomicBool(val = b_val)
    }

    pub fn load(self, order: Ordering) -> bool {
        return core_atomic::__toka_atomic_load(self.val#, order) > 0
    }

    pub fn store(self, v: bool, order: Ordering) {
        auto b_val# = 0
        if v { b_val = 1 }
        core_atomic::__toka_atomic_store(self.val#, b_val, order)
    }

    pub fn swap(self, v: bool, order: Ordering) -> bool {
        auto b_val# = 0
        if v { b_val = 1 }
        return core_atomic::__toka_atomic_swap(self.val#, b_val, order) > 0
    }

    pub fn compare_exchange(
        self, current: bool, new_val: bool, success: Ordering, failure: Ordering
    ) -> (bool, bool) {
        auto c_val# = 0
        if current { c_val = 1 }
        auto n_val# = 0
        if new_val { n_val = 1 }
        auto (res, ok) = core_atomic::__toka_atomic_compare_exchange(
            self.val#, c_val, n_val, success, failure
        )
        return (res > 0, ok)
    }
}

// Global Fences (Re-exports)
pub fn fence(order: Ordering) {
    core_atomic::fence(order)
}

pub fn fence_acquire() {
    core_atomic::fence_acquire()
}

pub fn fence_release() {
    core_atomic::fence_release()
}
