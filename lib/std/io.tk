import core/types::{usize, char, ADDR0}
import std/string::{String}
import core/libc::*
import core/result::{Result}

// Intrinsic
// Intrinsic
extern fn println(fmt: str, ...) -> void

// Specific Result Types to avoid Generic Instantiation B
pub shape File (
    *handle: void, // FILE*
    opened: bool,
    owned: bool
)

// Convenience Aliases for Generic Instantiation
alias IoResult = Result<File, String>
alias IoStringResult = Result<String, String>
alias IoSizeResult = Result<usize, String>

impl File@encap {
    pub *
    fn drop(self#) {
        unsafe {
            if self.owned && self.opened && self.*handle != (ADDR0 as *void) {
                libc_fclose(self.*handle)
                self.opened = false
                self.*handle = ADDR0 as *void
            }
        }
    }
    
    // Non-owning clone (Weak Reference) to satisfy strict pointer rules
    pub fn clone(self) -> File {
        return File(
            *handle = self.*handle,
            opened = self.opened,
            owned = false
        )
    }
}

impl File {
    pub fn open(path: String, mode: String) -> Result<File, String> {
        unsafe {
            auto *p = libc_fopen(path.c_str(), mode.c_str())
            if *p == (ADDR0 as *void) {
                return IoResult::Err(String::from("Failed to open file"))
            }
            auto f# = File(
                *handle = *p,
                opened = true,
                owned = true
            )
            auto res = IoResult::Ok(f)
            f.owned = false
            return res
        }
    }
    
    pub fn close(self#) {
        unsafe {
            if self.opened {
                libc_fclose(self.*handle)
                self.opened = false
                self.*handle = ADDR0 as *void
            }
        }
    }
    
    pub fn read_to_string(self) -> Result<String, String> {
        unsafe {
            if !self.opened { 
                return IoStringResult::Err(String::from("File not open"))
            }
            
            // Get size
            libc_fseek(self.*handle, 0, 2) // SEEK_END
            auto size = libc_ftell(self.*handle)
            libc_rewind(self.*handle)
            
            if size <= 0 { 
                return IoStringResult::Ok(String::from(""))
            }
            
            // Alloc temp buffer using libc_malloc
            auto *buf# = libc_malloc((size + 1) as usize) as *[char]
            
            // Read
            auto count = libc_fread(*buf as *void, 1, size as usize, self.*handle)
            buf[count] = 0 as char
            
            // Make String (copies data)
            auto s# = String::from_with_len(*buf, count as i32)
            
            // Free temp
            libc_free(*buf as *void)
            
            auto res = IoStringResult::Ok(s)
            // s#.unsafe_forget() // Handled by Move
            return res
        }
    }
    
    pub fn write(self, s: String) -> usize {
        unsafe {
            if !self.opened { return 0 as usize }
            return libc_fwrite(s.c_str() as *void, 1, s.len() as usize, self.*handle)
        }
    }
    pub fn is_eof(self) -> bool {
        unsafe {
            if !self.opened { return true }
            return libc_feof(self.*handle) != 0
        }
    }

    pub fn read(self, *buf: u8, len: usize) -> IoSizeResult {
        unsafe {
            if !self.opened { 
                return IoSizeResult::Err(String::from("File not open"))
            }
            
            auto count = libc_fread(*buf as *void, 1, len, self.*handle)
            return IoSizeResult::Ok(count as usize)
        }
    }

    pub fn write_buf(self, *buf: u8, len: usize) -> usize {
        unsafe {
            if !self.opened { return 0 as usize }
            return libc_fwrite(*buf as *void, 1, len, self.*handle)
        }
    }

    pub fn read_line(self) -> Result<String, String> {
        unsafe {
            if !self.opened { 
                 return IoStringResult::Err(String::from("File not open"))
            }
            
            auto s# = String::from("")
            // Loop char by char
            // TODO: optimize with buffering later if needed
            
            // We use an infinite loop and break
            auto done# = false
            while !done {
                auto c = libc_fgetc(self.*handle)
                
                if c == -1 { // EOF
                    done = true
                } else {
                    auto ch = c as char
                    s#.push_char(ch) // Appends to String
                    if ch == 10 as char { // \n
                        done = true
                    }
                }
            }
            
            auto res = IoStringResult::Ok(s)
            // s#.unsafe_forget() // Handled by Move
            return res
        }
    }

    pub fn flush(self) {
        unsafe {
            if self.opened {
                libc_fflush(self.*handle)
            }
        }
    }

    pub fn seek(self, offset: i64, whence: i32) -> i32 {
        unsafe {
            if !self.opened { return -1 }
            return libc_fseek(self.*handle, offset, whence)
        }
    }

    pub fn tell(self) -> i64 {
        unsafe {
            if !self.opened { return -1:i64 }
            return libc_ftell(self.*handle)
        }
    }
}

// === Global I/O Functions ===

pub fn stdin() -> File {
    unsafe {
        auto *p = libc_fdopen(0, "r" as *char)
        return File(*handle = *p, opened = (*p != null), owned = false)
    }
}

pub fn stdout() -> File {
    unsafe {
        auto *p = libc_fdopen(1, "w" as *char)
        return File(*handle = *p, opened = (*p != null), owned = false)
    }
}

pub fn stderr() -> File {
    unsafe {
        auto *p = libc_fdopen(2, "w" as *char)
        return File(*handle = *p, opened = (*p != null), owned = false)
    }
}

pub fn print(s: String) {
    auto out = stdout()
    out.write(s)
}

// === File Utilities ===

pub fn exists(path: String) -> bool {
    unsafe {
        auto *p = libc_fopen(path.c_str(), "r" as *char)
        if *p != null {
            libc_fclose(*p)
            return true
        }
        return false
    }
}

pub fn remove_file(path: String) -> bool {
    unsafe {
        return libc_remove(path.c_str()) == 0
    }
}

pub fn rename_file(old_path: String, new_path: String) -> bool {
    unsafe {
        return libc_rename(old_path.c_str(), new_path.c_str()) == 0
    }
}
