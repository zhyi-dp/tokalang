import std/sys/os as sys
import std/string::{String}
import core/types::{Addr, ADDR0}
import std/io
import core/result::{Result}
import core/option::{Option}

// Helpers to workaround potential scope visibility issue in impl blocks
fn call_readdir(h: Addr) -> String {
    return sys::readdir_impl(h as Addr)
}

fn call_closedir(h: Addr) {
    sys::closedir_impl(h as Addr)
}

fn call_opendir(path: String) -> Addr {
    return sys::opendir_impl(path.c_str() as Addr)
}

fn call_mkdir(path_addr: Addr) -> bool {
    return sys::mkdir_impl(path_addr)
}

fn call_rmdir(path: String) -> bool {
    return sys::rmdir_impl(path.c_str() as Addr)
}

pub shape ReadDir (
    handle: Addr,
    finished#: bool
)

impl ReadDir {
    pub fn next(self) -> String {
        unsafe {
            if self.finished {
                return String::from("")
            }
            
            auto name = call_readdir(self.handle)
            if name.len() == 0 {
                self.finished = true
                call_closedir(self.handle)
                return String::from("")
            }
            return name
        }
    }
    
    pub fn close(self#) {
        unsafe {
            if self.finished == false {
                call_closedir(self.handle)
                self.finished = true
            }
        }
    }
}

pub fn read_dir(path: String) -> ReadDir {
    unsafe {
        auto h = call_opendir(path)
        if h == (0:Addr) {
            // Return finished iterator on failure
            return ReadDir(handle = h, finished = true)
        }
        return ReadDir(
            handle = h,
            finished = false
        )
    }
}

pub fn create_dir(path: String) -> bool {
    return call_mkdir(path.c_str() as Addr)
}

pub fn remove_dir(path: String) -> bool {
    return call_rmdir(path)
}

fn call_exists(path: String) -> bool {
    return sys::path_exists(path.c_str() as Addr)
}

pub fn exists(path: String) -> bool {
    unsafe {
        return call_exists(path)
    }
}

pub shape Metadata(
    len: u64,
    mode: u32,
    modified: i64
)

impl Metadata {
     pub fn is_dir(self) -> bool {
         return sys::stat_is_dir_impl(self.mode)
     }
     
     pub fn is_file(self) -> bool {
         return sys::stat_is_file_impl(self.mode)
     }
     
     pub fn len(self) -> u64 {
         return self.len
     }
     
     // Returns unix timestamp in seconds
     pub fn modified(self) -> i64 {
         return self.modified
     }
}

alias FsResult = Result<Metadata, String>

pub fn metadata(path: String) -> Result<Metadata, String> {
    unsafe {
        auto handle = sys::stat_impl(path.c_str() as Addr)
        if handle == 0:Addr {
            return FsResult::Err(String::from("Path not found"))
        }
        
        auto m = Metadata(
            len = sys::stat_get_size_impl(handle),
            mode = sys::stat_get_mode_impl(handle),
            modified = sys::stat_get_mtime_impl(handle)
        )
        
        sys::stat_free_impl(handle)
        return FsResult::Ok(m)
    }
}
