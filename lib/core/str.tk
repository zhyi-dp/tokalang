import core/types::{char, byte, usize, Addr, Char32}
import core/option::{Option}
import core/result::{Result}
import core/traits::{@encap, @PartialEq, @PartialOrd}
import core/utf8::{Cursor, REPLACEMENT_CHAR}
import core/memory::{copy_memory, compare_memory}
import core/internal/runtime::__toka_panic_handler


extern fn libc_strlen(*s: char) -> usize

// A memory-safe, zero-allocation reference to a string view
pub shape str(
    &buf$: [char], //$ inner immutable
    len$: usize      ////$ inner immutable
)

impl str@encap {    
    pub fn clone(self) -> str <- self {
        return str(&buf = self.&buf, len = self.len)
    }
    
    fn drop(self#) {}
}

impl str@PartialEq {
    pub fn eq(self, other: str) -> bool {
        return self.equals(other)
    }
}

impl str@PartialOrd {
    pub fn cmp(self, other: str) -> i32 {
        unsafe {
            auto i#: usize = 0
            loop i < self.len && i < other.len {
                auto *p1 = &(self.buf[i]) as *char
                auto *p2 = &(other.buf[i]) as *char
                if *p1 < *p2 { return -1 }
                if *p1 > *p2 { return 1 }
                i = i + 1
            }
            if self.len < other.len { return -1 }
            if self.len > other.len { return 1 }
            return 0
        }
    }
}

pub shape ViewStrSplitIterator(
    &buf$: [char],
    len$: usize,
    pos#: usize,
    sep: str,
    finished#: bool
)

impl ViewStrSplitIterator@encap {    
    pub fn clone(self) -> ViewStrSplitIterator <- self {
        return ViewStrSplitIterator(&buf = self.&buf, len = self.len, pos = self.pos, sep = self.sep.clone(), finished = self.finished)
    }
    
    fn drop(self#) {}
}

impl ViewStrSplitIterator {
    pub fn raw_ptr(self) -> *char {
        if self.len == 0 { return null as *char }
        unsafe {
            auto cpy = self.clone()
            auto ret_val: usize = 0
            copy_memory(&ret_val as Addr, &cpy as Addr, 8)
            return ret_val as *char
        }
    }

    pub fn next(self#) -> Option<str> {
        if self.finished {
            return Option<str>::None
        }

        // If separator is empty, return the whole remaining string and finish
        if self.sep.len == 0 {
            self.finished = true
            auto remaining = self.len - self.pos
            unsafe {
                auto b_addr = self.raw_ptr() as Addr
                auto ptr_addr = b_addr + self.pos
                auto ret = str(&buf = self.&buf, len = remaining)
                copy_memory(&ret as Addr, &ptr_addr as Addr, 8)
                return Option<str>::Some(ret)
            }
        }
        
        unsafe {
            auto self_addr = self.raw_ptr() as Addr
            auto sep_addr = self.sep.raw_ptr() as Addr
            auto i# = self.pos
            auto max_i#: usize = 0
            if self.len >= self.sep.len + self.pos {
                max_i = self.len - self.sep.len
            } else {
                max_i = 0
                if self.len < self.pos {
                    max_i = 0
                }
            }
            
            auto found# = false
            if self.len >= self.sep.len + self.pos {
                loop i <= max_i {
                    if compare_memory(self_addr + i, sep_addr, self.sep.len) == 0 {
                        found = true
                        break
                    }
                    i = i + 1
                }
            }
            
            auto start = self.pos
            if found {
                auto segment_len = i - start
                self.pos = i + self.sep.len
                
                auto b_addr = self.raw_ptr() as Addr
                auto ptr_addr = b_addr + start
                auto ret = str(&buf = self.&buf, len = segment_len)
                copy_memory(&ret as Addr, &ptr_addr as Addr, 8)
                return Option<str>::Some(ret)
            } else {
                self.finished = true
                auto segment_len = self.len - start
                auto b_addr = self.raw_ptr() as Addr
                auto ptr_addr = b_addr + start
                auto ret = str(&buf = self.&buf, len = segment_len)
                copy_memory(&ret as Addr, &ptr_addr as Addr, 8)
                return Option<str>::Some(ret)
            }
        }
    }
}

pub shape ViewStrLinesIterator(
    split_iter#: ViewStrSplitIterator
)

impl ViewStrLinesIterator@encap {    
    pub fn clone(self) -> ViewStrLinesIterator <- self {
        return ViewStrLinesIterator(split_iter = self.split_iter.clone())
    }
    
    fn drop(self#) {}
}

impl ViewStrLinesIterator {
    pub fn next(self#) -> Option<str> {
        auto line_opt = self.split_iter#.next()
        if line_opt.is_none() {
            return Option<str>::None
        }
        auto line = line_opt.unwrap()
        auto byte_len = line.byte_count()
        if byte_len > 0 {
            auto last_byte = line.as_bytes().at(byte_len - 1).unwrap()
            if last_byte == 13:byte { // '\r'
                return Option<str>::Some(line.substr(0, byte_len - 1))
            }
        }
        return Option<str>::Some(line)
    }
}

impl str {
    pub fn byte_count(self) -> usize {
        return self.len
    }

    pub fn len(self) -> usize {
        return self.len
    }

    pub fn buf(self) -> &[char] <- self {
        return self.&buf
    }

    pub fn count(self) -> usize {
        auto iter# = self.chars()
        auto count#: usize = 0
        loop iter#.next().is_some() {
            count = count + 1
        }
        return count
    }

    pub fn slice(self, start: i32, end: i32) -> res: str
    effects:
        res.&buf <- self.buf
    {
        auto total = self.count() as i32
        auto actual_start# = start
        auto actual_end# = end
        
        if actual_start < 0 {
            actual_start = total + actual_start
        }
        if actual_end < 0 {
            actual_end = total + actual_end
        }
        if actual_start < 0 { actual_start = 0 }
        if actual_end < 0 { actual_end = 0 }
        if actual_start > total { actual_start = total }
        if actual_end > total { actual_end = total }
        if actual_start >= actual_end {
            return str(&buf = self.&buf, len = 0)
        }
        
        auto iter# = self.chars()
        auto count#: i32 = 0
        loop count < actual_start {
            if iter#.next().is_none() {
                return str(&buf=self.&buf, len=0)
            }
            count = count + 1
        }
        
        auto byte_start = iter.current_pos()
        
        loop count < actual_end {
            if iter#.next().is_none() {
                break
            }
            count = count + 1
        }
        
        auto byte_len = iter.current_pos() - byte_start
        unsafe {
            auto base_addr = &(self.buf[byte_start]) as Addr
            return str(&buf = (base_addr as *[char]) as &[char], len = byte_len)
        }
    }

    pub fn at(self, idx: usize) -> Option<Char32> {
        auto iter# = self.chars()
        auto count#: usize = 0
        loop true {
            auto opt = iter#.next()
            if opt.is_none() { break }
            if count == idx {
                return opt
            }
            count = count + 1
        }
        return Option<Char32>::None
    }

    pub fn byte_at(self, idx: usize) -> char {
        if idx >= self.len { return 0:char }
        unsafe {
            return self.buf[idx]
        }
    }

    pub fn chars(self) -> Cursor <- self {
        return Cursor(&buf = self.&buf, len = self.len, pos = 0)
    }

    pub fn char_len(self) -> usize {
        auto iter# = self.chars()
        auto count#: usize = 0
        loop iter#.next().is_some() {
            count = count + 1
        }
        return count
    }

    pub fn char_at(self, char_idx: usize) -> Option<Char32> {
        auto iter# = self.chars()
        auto count#: usize = 0
        loop true {
            auto opt = iter#.next()
            if opt.is_none() { break }
            if count == char_idx {
                return opt
            }
            count = count + 1
        }
        return Option<Char32>::None
    }

    pub fn substr_chars(self, start_char: usize, char_length: usize) -> res: str
    effects:
        res.&buf <- self.buf
    {
        auto iter# = self.chars()
        auto count#: usize = 0

        // Skip until start_char
        loop count < start_char {
            if iter#.next().is_none() {
                return str(&buf = self.&buf, len = 0)
            }
            count = count + 1
        }

        auto byte_start = iter.current_pos()
        auto take_count#: usize = 0

        // Take char_length
        loop take_count < char_length {
            if iter#.next().is_none() {
                break
            }
            take_count = take_count + 1
        }

        auto byte_len = iter.current_pos() - byte_start
        return self.substr(byte_start, byte_len)
    }

    pub fn is_valid_utf8(self) -> bool {
        auto iter# = self.chars()
        loop true {
            auto opt = iter#.next()
            if opt.is_none() { break }
            if opt.unwrap() == REPLACEMENT_CHAR { return false }
        }
        return true
    }

    pub fn as_bytes(self) -> bytes {
        unsafe {
            auto cpy = self.clone()
            auto ret = bytes(&buf = null as *[byte] as &[byte], len = self.len)
            copy_memory(&ret as Addr, &cpy as Addr, 16)
            return ret
        }
    }

    pub fn bytes(self) -> bytes {
        return self.as_bytes()
    }

    pub fn is_empty(self) -> bool {
        return self.len == 0
    }

    pub fn equals(self, other: str) -> bool {
        if self.len != other.len { return false }
        if self.len == 0 { return true }
        unsafe {
            return compare_memory(self.raw_ptr() as Addr, other.raw_ptr() as Addr, self.len) == 0
        }
    }

    pub fn starts_with(self, prefix: str) -> bool {
        if prefix.len > self.len { return false }
        if prefix.len == 0 { return true }
        unsafe {
            return compare_memory(self.raw_ptr() as Addr, prefix.raw_ptr() as Addr, prefix.len) == 0
        }
    }

    pub fn ends_with(self, suffix: str) -> bool {
        if suffix.len > self.len { return false }
        if suffix.len == 0 { return true }
        unsafe {
            auto self_addr = self.raw_ptr() as Addr
            auto offset_addr = self_addr + (self.len - suffix.len)
            return compare_memory(offset_addr, suffix.raw_ptr() as Addr, suffix.len) == 0
        }
    }

    pub fn starts_with_char(self, c: Char32) -> bool {
        auto opt = self.at(0)
        if opt.is_none() { return false }
        return opt.unwrap() == c
    }

    pub fn ends_with_char(self, c: Char32) -> bool {
        auto total = self.count()
        if total == 0 { return false }
        auto opt = self.at(total - 1)
        if opt.is_none() { return false }
        return opt.unwrap() == c
    }

    pub fn index_of_str(self, needle: str) -> Option<usize> {
        if needle.len == 0 { return Option<usize>::Some(0) }
        if needle.len > self.len { return Option<usize>::None }
        unsafe {
            auto self_addr = self.raw_ptr() as Addr
            auto needle_addr = needle.raw_ptr() as Addr
            auto i#: usize = 0
            auto max_i = self.len - needle.len
            loop i <= max_i {
                if compare_memory(self_addr + i, needle_addr, needle.len) == 0 {
                    return Option<usize>::Some(i)
                }
                i = i + 1
            }
            return Option<usize>::None
        }
    }

    pub fn index_of(self, c: char) -> Option<usize> {
        unsafe {
            auto i#: usize = 0
            loop i < self.len {
                if self.buf[i] == c {
                    return Option<usize>::Some(i)
                }
                i = i + 1
            }
            return Option<usize>::None
        }
    }

    pub fn contains_char(self, c: char) -> bool {
        return self.index_of(c).is_some()
    }

    pub fn last_index_of(self, c: char) -> Option<usize> {
        unsafe {
            auto i# = self.len
            loop i > 0 {
                i = i - 1
                if self.buf[i] == c {
                    return Option<usize>::Some(i)
                }
            }
            return Option<usize>::None
        }
    }

    pub fn substring(self, start: usize, end: usize) -> str {
        return self.slice(start as i32, end as i32)
    }



    pub fn count_char(self, c: Char32) -> usize {
        auto iter# = self.chars()
        auto cnt#: usize = 0
        loop true {
            auto opt = iter#.next()
            if opt.is_none() { break }
            if opt.unwrap() == c {
                cnt = cnt + 1
            }
        }
        return cnt
    }

    pub fn substr(self, pos: usize, length: usize) -> res: str
    effects:
        res.&buf <- self.buf
    {
        auto actual_len# = length
        if pos >= self.len { 
            return str(&buf = self.&buf, len = 0) 
        }
        if pos == 0 && actual_len >= self.len { 
            return self.clone() 
        }
        
        if pos + actual_len > self.len { 
            actual_len = self.len - pos 
        }
        
        unsafe {
            auto b_addr = self.raw_ptr() as Addr
            auto ptr_addr = b_addr + pos
            auto ret = str(&buf = self.&buf, len = actual_len)
            copy_memory(&ret as Addr, &ptr_addr as Addr, 8)
            return ret
        }
    }

    pub fn trim(self) -> res: str
    effects:
        res.&buf <- self.buf
    {
        return self.trim_start().trim_end()
    }

    pub fn trim_start(self) -> res: str
    effects:
        res.&buf <- self.buf
    {
        if self.len == 0 { return self.clone() }
        auto start#: usize = 0
        unsafe {
            loop start < self.len {
                auto c = self.buf[start]
                if c != 32:char && c != 9:char && c != 10:char && c != 13:char {
                    break
                }
                start = start + 1
            }
            if start == 0 { return self.clone() }
            if start == self.len { return str(&buf = self.&buf, len = 0) }
            
            auto b_addr = self.raw_ptr() as Addr
            auto ptr_addr = b_addr + start
            auto ret = str(&buf = self.&buf, len = self.len - start)
            copy_memory(&ret as Addr, &ptr_addr as Addr, 8)
            return ret
        }
    }

    pub fn trim_end(self) -> res: str
    effects:
        res.&buf <- self.buf
    {
        if self.len == 0 { return self.clone() }
        auto end# = self.len
        unsafe {
            loop end > 0 {
                auto c = self.buf[end - 1]
                if c != 32:char && c != 9:char && c != 10:char && c != 13:char {
                    break
                }
                end = end - 1
            }
            if end == self.len { return self.clone() }
            return str(&buf = self.&buf, len = end)
        }
    }

    pub fn split(self, sep: str) -> ViewStrSplitIterator <- self {
        return ViewStrSplitIterator(&buf = self.&buf, len = self.len, pos = 0, sep = sep.clone(), finished = false)
    }

    pub fn lines(self) -> ViewStrLinesIterator <- self {
        auto nl_str = _internal_str_cast("\n")
        auto s_iter = self.split(nl_str)
        return ViewStrLinesIterator(split_iter = s_iter)
    }

    pub fn to_i32(self) -> Option<i32> {
        if self.len == 0 { return Option<i32>::None }
        unsafe {
            auto i#: usize = 0
            auto ret#: i32 = 0
            auto sign#: i32 = 1
            if self.buf[0] == '-' {
                sign = -1
                i = 1
                if self.len == 1 { return Option<i32>::None }
            } else if self.buf[0] == '+' {
                i = 1
                if self.len == 1 { return Option<i32>::None }
            }
            loop i < self.len {
                auto c = self.buf[i]
                if c < '0' || c > '9' {
                    return Option<i32>::None
                }
                auto digit = (c as i32) - 48
                ret = ret * 10 + digit
                i = i + 1
            }
            return Option<i32>::Some(ret * sign)
        }
    }

    pub fn raw_ptr(self) -> *char {
        if self.len == 0 { return null as *char }
        unsafe {
            auto cpy = self.clone()
            auto ret_val: usize = 0
            copy_memory(&ret_val as Addr, &cpy as Addr, 8)
            return ret_val as *char
        }
    }

    pub fn as_cstr(self) -> cstr {
        return cstr(*buf = self.raw_ptr())
    }
}

fn _internal_str_cast(s: str) -> str {
    return s.clone()
}

// A raw null-terminated C-string pointer representation
pub shape cstr(
    *buf: char
)

impl cstr@encap {
    pub fn clone(self) -> cstr <- self {
        return cstr(*buf = self.*buf)
    }

    pub fn raw_ptr(self) -> *char {
        return self.*buf
    }

    fn drop(self#) {}
}

impl cstr@delegate {
    pub fn target(self) -> str {
        return self.as_str()
    }
}

impl cstr {
    pub fn as_str(self) -> res: str
    effects:
        res.&buf <- self
    {
        unsafe {
            if self.*buf == null {
                return str(&buf = null as *[char] as &[char], len = 0)
            }
            auto len = libc_strlen(self.*buf)
            return str(&buf = (self.*buf as *[char]) as &[char], len = len)
        }
    }
}

// ============================================================================
// bytes (Raw Physical Byte Stream View) & UnicodeError
// ============================================================================

pub shape UnicodeError(
    invalid_byte: byte,
    position: usize
)

pub shape bytes(
    &buf$: [byte],
    len$: usize
)

impl bytes@encap {
    pub fn clone(self) -> bytes <- self {
        return bytes(&buf = self.&buf, len = self.len)
    }

    fn drop(self#) {}
}

impl bytes {
    pub fn size(self) -> usize {
        return self.len
    }

    pub fn len(self) -> usize {
        return self.size()
    }

    pub fn raw_ptr(self) -> *byte {
        if self.len == 0 { return null as *byte }
        unsafe {
            auto cpy = self.clone()
            auto ret_val: usize = 0
            copy_memory(&ret_val as Addr, &cpy as Addr, 8)
            return ret_val as *byte
        }
    }

    pub fn is_empty(self) -> bool {
        return self.len == 0
    }

    pub fn at(self, idx: usize) -> Option<byte> {
        if idx >= self.len {
            return Option<byte>::None
        }
        unsafe {
            return Option<byte>::Some(self.buf[idx])
        }
    }

    pub fn slice_bytes(self, start: usize, end: usize) -> bytes {
        if start > end || end > self.len {
            __toka_panic_handler("bytes::slice_bytes: out of bounds")
        }
        unsafe {
            auto new_len = end - start
            auto base_addr = &(self.buf[start]) as Addr
            auto ret = bytes(&buf = null as *[byte] as &[byte], len = new_len)
            copy_memory(&ret as Addr, &base_addr as Addr, 8)
            return ret
        }
    }

    pub fn try_to_str(self) -> Result<str, UnicodeError> {
        if self.len == 0 {
            unsafe {
                auto ret = str(&buf = null as *[char] as &[char], len = 0)
                return Result<str, UnicodeError>::Ok(ret)
            }
        }
        
        unsafe {
            auto &c_buf = &(self.buf[0]) as *[char] as &[char]
            auto iter# = Cursor(&buf = &c_buf, len = self.len, pos = 0)
            loop true {
                auto prev_pos = iter.current_pos()
                auto opt = iter#.next()
                if opt.is_none() { break }
                if opt.unwrap() == REPLACEMENT_CHAR {
                    auto bad_byte = self.buf[prev_pos]
                    return Result<str, UnicodeError>::Err(UnicodeError(invalid_byte = bad_byte, position = prev_pos))
                }
            }
            
            auto cpy = self.clone()
            auto ret = str(&buf = null as *[char] as &[char], len = self.len)
            copy_memory(&ret as Addr, &cpy as Addr, 16)
            return Result<str, UnicodeError>::Ok(ret)
        }
    }


}
