// core/prelude.tk
pub import core/types::*
pub import core/str::{str, cstr, ViewStrSplitIterator, bytes, UnicodeError}
pub import core/string::{string}
pub import core/option::{Option}
pub import core/result::{Result}
pub import core/task::{TaskHandle}

import core/internal/runtime::__toka_panic_handler;

pub fn panic(message: str) {
    __toka_panic_handler(message)
}

pub fn assert(condition: bool, message: str) {
    if (!condition) {
        panic(message)
    }
}