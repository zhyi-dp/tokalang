// import core/prelude -- Cycle break

import core/libc::libc_exit

pub shape Maybe<'T> (
    Some('T) = 1 |
    None = 0
)

impl<'T> Maybe<'T> {
    pub fn is_some(self) -> bool {
        match self {
            auto Maybe<'T>::Some(_) => return true
            _ => return false
        }
    }

    pub fn is_none(self) -> bool {
        return self.is_some() == false
    }

    pub fn unwrap(self) -> 'T {
        match self {
            auto Maybe<'T>::Some('val) => return 'val
            _ => {
                libc_exit(1)
                return self.unwrap() 
            }
        }
    }

    pub fn unwrap_or(self, 'def_val: 'T) -> 'T {
        match self {    
            auto Maybe<'T>::Some('val) => return 'val
            _ => return 'def_val
        }
    }
}

pub alias Option<'T> = Maybe<'T>

