// lib/core/comptime.tk
// Toka's Zero-Macro Compile-Time Reflection & Metaprogramming APIs.
// This module provides interfaces that are physically evaluated 
// and unrolled by the Toka compiler's Sema phase.

import core/types::*

// ==========================================
// 1. Metadata Shapes ( Sema )
// ==========================================

pub shape TypeKind(
    Primitive |
    Struct |
    Union |
    Enum |
    Tuple |
    Pointer |
    Array
)


pub shape FieldInfo(
    name: str,
    type_name: str, // ()
    offset: usize, 
    size: usize 
)

// T
pub shape TypeInfo(
    name: str,
    kind: TypeKind,
    fields: RowFat<FieldInfo>, 
    size: usize,
    align: usize
)

// ==========================================
// 2.  ( Sema )
// ==========================================

// ()
pub fn reflect<'T>() -> TypeInfo {
    // [Compiler Hook] Sema  TypeInfo
    unsafe {
        auto dummy: TypeInfo
        return dummy
    }
}


pub fn is_pointer<'T>() -> bool {
    // [Compiler Hook]
    return false
}

// ==========================================
// 3.  ()
// ==========================================


pub fn compile_error(msg: str) {
    // [Compiler Hook] Sema  `msg`
}


pub fn assert(condition: bool, msg: str) {
    // [Compiler Hook]
}

// ==========================================
// 4.  (AST )
// ==========================================

impl FieldInfo {
    // FieldInfo
    // self  `#`
    // obj  `^` T
    pub fn get<T, V>(self, obj: T) -> V {
        // [Compiler Hook] Sema  `self`
        // `obj.`
        unsafe {
            auto dummy: V
            return dummy
        }
    }

    // FieldInfo
    // obj  obj  `#`
    pub fn set<T, V>(self, obj#: T, val: V) {
        // [Compiler Hook] Sema `obj. = val`
    }
}

// =====================================
// ===  (Usage Convention) ===
// =====================================
// 1. `comptime::reflect<T>().fields`
// 2.  `for` Toka
// `inline for`
// 3.  `field.get(obj)`  `V`
