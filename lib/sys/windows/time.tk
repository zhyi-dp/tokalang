import core/types::{Addr}
import sys/os/abi::*
import sys/libc::*

pub fn sys_clock_realtime(ts_addr: Addr) -> bool { unsafe { return toka_clock_realtime(ts_addr) == 1 } }
pub fn sys_clock_monotonic(ts_addr: Addr) -> bool { unsafe { return toka_clock_monotonic(ts_addr) == 1 } }
